# Used by `docker compose up` to configure the MySQL container and the backend's
# demo-mode admin login. Copy this file to `.env` (same folder as docker-compose.yml)
# and replace the placeholder values before running Docker Compose:
#
#   cp .env.example .env
#
# This root .env is only read by Docker Compose — it's separate from
# back-end/.env and front-end/.env, which are used for native (non-Docker) dev.

MYSQL_DATABASE=shophub
MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_USER=shophub
MYSQL_PASSWORD=change-me-db-password

# When true, one-click demo login buttons appear on /admin/login and /login,
# and their credentials are published by the public /api/config endpoint —
# only enable this on throwaway demo deployments.
DEMO_MODE=false
DEMO_ADMIN_EMAIL=admin@shophub.test
DEMO_ADMIN_PASSWORD=change-me-demo-password
DEMO_CUSTOMER_EMAIL=customer@shophub.test
DEMO_CUSTOMER_PASSWORD=change-me-demo-password
